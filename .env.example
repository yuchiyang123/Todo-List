# Must exactly match the values Mini-SSO uses, so todo-api can validate
# the same JWT cookie without calling back to Mini-SSO on every request.
JWT_ISSUER=yourdomain.com
JWT_AUDIENCE=yourdomain.com
JWT_KEY=replace-with-the-same-key-as-mini-sso

# Mini-SSO's own public origin (its nginx, not this app's gateway). Baked into
# the frontend build so the Google/GitHub login buttons link directly to it —
# required so OAuth's registered redirect_uri isn't broken by proxying.
MINI_SSO_ORIGIN=http://localhost:12080

# Port this stack's nginx gateway (frontend + reverse proxy) is published on.
WEB_PORT=8081
